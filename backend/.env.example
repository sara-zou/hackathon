# Subconscious platform API key — https://subconscious.dev/platform
SUBCONSCIOUS_API_KEY=your_subconscious_api_key_here

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# The public URL of this backend — required for the Wikipedia function tool
# Local dev: run `npx ngrok http 3001` and paste the https URL here
# Production: your Vercel deployment URL (e.g. https://livecheck.vercel.app)
BACKEND_URL=http://localhost:3001
